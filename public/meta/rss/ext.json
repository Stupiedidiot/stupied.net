---
layout: none
---
{% assign FEED = site.art | concat: site.posts | sort: 'date' | reverse %}
[
    {%- for item in FEED limit: 15 -%}
        {
            "link": {{ item.url | prepend: site.url | jsonify }},
            "title": {{ item.title | jsonify }},
            "date": {{ item.date | date: "%Y-%m-%dT%H-%M" | jsonify }}
        }
        {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
]