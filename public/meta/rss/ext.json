---
layout: none
---
[
    {% assign FEED = site.data.rss | filterFuture %}
    {%- for item in FEED limit: 15 -%}
        {
            "link": {{ item.link | prepend: site.url | jsonify }},
            "title": {{ item.title | jsonify}},
            "description": {{ item.desc | default: "( •̀ ω •́ )✧" | strip_html | markdownify | strip_html | jsonify }},
            "date": {{ item.date | date: "%Y-%m-%dT%H-%M" | jsonify }}
        }
        {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
]