---
layout: rss
title: Stupied Reviews RSS Feed
description: Updates of the reviews written by Stupied
---
{%- assign REVIEWS = site.reviews
    | where_exp: 'e', 'e.path contains "/f/"'
    | sort: "reviewed"
    | reverse
-%}

{%- for item in REVIEWS limit: 15 -%}
    {%- capture title -%}
        {{ item.title | default: item.filename }}{% if item.release %} ({{ item.release }}){% endif %}
    {%- endcapture -%}
    {%- assign slug = item.slug | downcase -%}
    <item>
    <title>{{ item.title | escape }}</title>
    <pubDate>{{ item.date | date: "%a, %d %b %Y %T" | append: " PST"}}</pubDate>
    <link>{{ site.url | append: '/chez/reviews/#' | append: slug }}</link>
    <guid isPermaLink="false">{{ slug }}-{{ item.date | date: "%Y-%m-%d" }}</guid>
    <description>
        {%- capture description -%}
            {%- if item.url contains 'disney/' -%}
                <img src="/chez/reviews/img/{{ slug }}.jpg" style="max-width:100%;"/>
            {%- endif -%}
            {{ item.content | markdownify }}
        {%- endcapture -%}
        {{ description | escape }}
    </description>
</item>
{%- endfor -%}