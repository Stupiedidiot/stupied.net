---
layout: rss
title: Stupied's Microblog
description: RSS Feed for my microblog ramblings
---
{% assign micro_replace = 'img src="' | append: site.url | append: '/blog/micro/img/' %}

{% assign DATA = site.micro | reverse %}
{%- for item in DATA limit: 15 -%}
  {% if item.path contains '_unpublished' %}
      {% continue %}
  {% endif %}
  <item>
    <title>{{ item.title | escape }}</title>
    <pubDate>{{ item.date | date: "%a, %d %b %Y %T" | append: " PST"}}</pubDate>
    <link>{{ site.url }}/{{ item.date | date: "%Y-%m-%dT%H-%M" }}</link>
    <guid isPermaLink="false">{{ item.date | date: "%Y-%m-%dT%H-%M" }}</guid>
    <description>
      {%- capture description -%}
        {% assign file = item.path | prepend: 'snail/' %}
        {% capture micro %}{% cat file %}{% endcapture %}
        {{ micro | markdownify | replace: 'img src="img/', micro_replace }}
        {% if micro %}
            {{ micro | markdownify | replace: 'img src="img/', micro_replace }}
        {% endif %}
      {%- endcapture -%}
      {{ description | escape }}
    </description>
    {% if item.tags %}
        {% for tag in item.tags %}
          <category>{{ tag }}</category>
        {% endfor %}
    {% endif %}
  </item>
{%- endfor -%}